# =============================================
# Shieldhood Configuration for Bankr.bot
# =============================================

shield:
  enabled: true
  version: "2.1.0"
  log_level: "INFO"
  require_confirmation: true          # Default: require human confirmation for suspicious/malicious actions

# Spending Policy (in USD)
spending:
  daily_limit_usd: 5000
  tx_limit_usd: 1000
  reset_daily_at: "00:00"             # Optional: time when daily limit resets

# Address Allowlist
allowlist:
  enabled: true
  addresses:
    - "0xYourTrustedAddress1234567890abcdef"
    - "0xAnotherTrustedAddressHere"
    # Add your trusted addresses above

# Robinhood Chain Specific
chain:
  id: "robinhood"
  name: "Robinhood Chain"

# Security Tuning (Advanced)
security:
  entropy_threshold: 4.2
  max_decode_depth: 5
  invisible_unicode_detection: true

# Logging
logging:
  enabled: true
  save_scan_history: false            # Set to true if you want to keep scan history
  log_file: "shieldhood_logs.json"
